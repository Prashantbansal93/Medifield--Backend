# Required
MONGO_URI=mongodb://127.0.0.1:27017/medifield
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# Optional
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_CODE=MEDI-ADMIN-2026
WHOLESALER_WAIT_MINUTES=5
LOG_LEVEL=info

# OTP: in development, OTP codes are returned as `devOtp` in API responses and logged.
# Wire MSG91/Twilio later for production SMS; email provider for email OTP.

# Optional — enables Socket.IO multi-instance scaling
# REDIS_URL=redis://localhost:6379
